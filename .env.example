# Worker auth (the platform sends this as the X-Worker-Secret header).
WORKER_SECRET=change-me

# PeopleStrong portal login.
PEOPLESTRONG_USER=
PEOPLESTRONG_PASS=

# The worker writes NO database — it scrapes and returns results; the Everest
# platform ingests them. So there are no Supabase vars here.
PORT=8080
STORAGE_DIR=./storage
CONFIG_PATH=./config/peoplestrong.yml
HEADLESS=true

# Keep-alive: ping our own /health so the host doesn't idle us out. On Render,
# RENDER_EXTERNAL_URL is injected automatically, so this works with no config.
# Optional overrides: KEEPALIVE_URL=https://your-service.onrender.com
#                     KEEPALIVE_MS=600000   (set 0 to disable)
